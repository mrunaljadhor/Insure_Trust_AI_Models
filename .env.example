# InsureTrust AI — Environment Variables

# Groq API Key (free tier — get from https://console.groq.com)
# Used ONLY for claim summary generation (non-scoring)
GROQ_API_KEY=your_groq_key_here

# Application secret key
SECRET_KEY=change_this_in_production

# Database URL (default: SQLite)
DATABASE_URL=sqlite:///./insuretrust.db
